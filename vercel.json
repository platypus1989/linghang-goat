{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "installCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "linghang-goat.vercel.app"
        }
      ],
      "destination": "https://www.linghang-goat.org/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "linghang-goat.vercel.app"
        }
      ],
      "destination": "https://www.linghang-goat.org/:path*",
      "permanent": true
    }
  ]
}
